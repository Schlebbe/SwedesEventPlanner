@baseUrl = http://localhost:5000
@adminToken = dev-admin-token-change-me
@eventSlug = test-bingo-2026

### 1. Liveness
GET {{baseUrl}}/health

### 1. Readiness
GET {{baseUrl}}/health/ready

### 1. Service information
GET {{baseUrl}}/api

### 2. Admin status
GET {{baseUrl}}/api/admin/status
Authorization: Bearer {{adminToken}}

### 2. List admin events
GET {{baseUrl}}/api/admin/events
Authorization: Bearer {{adminToken}}

### 2. Create event
# Copy id -> {{eventId}} and slug -> {{eventSlug}} from the response.
POST {{baseUrl}}/api/admin/events
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "slug": "manual-bingo-2026",
  "name": "Manual Bingo 2026",
  "eventType": "bingo",
  "status": "active",
  "startsAt": "2026-07-02T17:00:00Z",
  "endsAt": "2026-07-16T17:00:00Z",
  "timeZone": "Europe/Stockholm"
}

### 2. Set event status
POST {{baseUrl}}/api/admin/events/{{eventSlug}}/status
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "status": "active"
}

### 3. Create team
# Copy id -> {{teamId}} from the response.
POST {{baseUrl}}/api/admin/events/{{eventSlug}}/teams
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "Blue"
}

### 4. Import CSV signup
POST {{baseUrl}}/api/admin/events/{{eventSlug}}/signups/import-csv
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "csvText": "Timestamp,Email Address,RuneScape Name,Availability,Daily Hours,Preferred Content,Notes,Team Preference\n2026-07-02T17:30:00Z,player@example.invalid,Sebbe,Evenings,3,Raids,Ready,Blue"
}

### 4. List signups
GET {{baseUrl}}/api/admin/events/{{eventSlug}}/signups
Authorization: Bearer {{adminToken}}

### 4. List participants
# Copy participant id -> {{participantId}} from the response.
GET {{baseUrl}}/api/admin/events/{{eventSlug}}/participants
Authorization: Bearer {{adminToken}}

### 5. Assign participant to team
POST {{baseUrl}}/api/admin/events/{{eventSlug}}/participants/{{participantId}}/assign-team
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "teamId": {{teamId}}
}

### 6. Create board
# Copy id -> {{boardId}} from the response.
POST {{baseUrl}}/api/admin/events/{{eventSlug}}/boards
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "Manual Board",
  "rows": 5,
  "columns": 5
}

### 7. Create tile
# Copy id -> {{tileId}} from the response.
POST {{baseUrl}}/api/admin/events/{{eventSlug}}/boards/{{boardId}}/tiles
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "title": "Scythe Drop",
  "description": "Count Scythe drops from manual activity payloads.",
  "positionX": 0,
  "positionY": 0,
  "sortOrder": 1
}

### 7. Create tile tier
# Copy id -> {{tileTierId}} from the response.
POST {{baseUrl}}/api/admin/events/{{eventSlug}}/tiles/{{tileId}}/tiers
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "tierNumber": 1,
  "title": "One drop",
  "description": "One matching item drop.",
  "scoreValue": 1,
  "isRequiredForBoardCompletion": true,
  "sortOrder": 1
}

### 8. Create item_count rule
# MVP setup allows one active rule per tier. Use separate tiles/tiers for point_threshold
# and external_competition_metric examples below.
POST {{baseUrl}}/api/admin/events/{{eventSlug}}/tiles/{{tileId}}/rules
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "tileTierId": {{tileTierId}},
  "ruleType": "item_count",
  "scope": "team",
  "isActive": true,
  "configJson": "{\"activityType\":\"item_drop\",\"itemIds\":[22486],\"requiredValue\":1,\"duplicatesCount\":true}"
}

### 8. Create point_threshold rule
# Copy a different tile id -> {{pointTileId}} and tier id -> {{pointTileTierId}} before running.
POST {{baseUrl}}/api/admin/events/{{eventSlug}}/tiles/{{pointTileId}}/rules
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "tileTierId": {{pointTileTierId}},
  "ruleType": "point_threshold",
  "scope": "team",
  "isActive": true,
  "configJson": "{\"activityType\":\"item_drop\",\"pointsTable\":[{\"itemId\":22486,\"points\":10}],\"requiredValue\":10}"
}

### 8. Create external_competition_metric rule
# Copy a different tile id -> {{externalTileId}} and tier id -> {{externalTileTierId}} before running.
POST {{baseUrl}}/api/admin/events/{{eventSlug}}/tiles/{{externalTileId}}/rules
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "tileTierId": {{externalTileTierId}},
  "ruleType": "external_competition_metric",
  "scope": "team",
  "isActive": true,
  "configJson": "{\"provider\":\"templeosrs\",\"externalCompetitionId\":{{externalCompetitionId}},\"metricType\":\"xp\",\"metricKey\":\"overall\",\"requiredValue\":1000000}"
}

### 8. List board/tile/tier/rule setup
GET {{baseUrl}}/api/admin/events/{{eventSlug}}/board-setup
Authorization: Bearer {{adminToken}}

### 9. Link externally-created TempleOSRS competition
# Set {{templeCompetitionId}} before running. Copy id -> {{externalCompetitionId}} from the response.
POST {{baseUrl}}/api/admin/events/{{eventSlug}}/external-competitions/templeosrs
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "externalId": "{{templeCompetitionId}}",
  "name": "Manual Temple Read Cache",
  "metricType": "xp",
  "metricKey": "overall"
}

### 9. List linked external competitions
GET {{baseUrl}}/api/admin/events/{{eventSlug}}/external-competitions
Authorization: Bearer {{adminToken}}

### 10. Trigger read-only Temple sync
POST {{baseUrl}}/api/admin/events/{{eventSlug}}/external-competitions/{{externalCompetitionId}}/sync
Authorization: Bearer {{adminToken}}

### 10. Cached Temple player metrics
GET {{baseUrl}}/api/admin/external-competitions/{{externalCompetitionId}}/player-metrics
Authorization: Bearer {{adminToken}}

### 10. Cached Temple team metrics
GET {{baseUrl}}/api/admin/external-competitions/{{externalCompetitionId}}/team-metrics
Authorization: Bearer {{adminToken}}

### 10. Unmatched Temple identities
GET {{baseUrl}}/api/admin/external-competitions/{{externalCompetitionId}}/unmatched-identities
Authorization: Bearer {{adminToken}}

### 11. Submit manual activity payload through Development-only endpoint
POST {{baseUrl}}/api/activity
Content-Type: application/json

{
  "playerName": "Schlebbe",
  "activityType": "item_drop",
  "source": "Theatre of Blood",
  "itemId": 22486,
  "itemName": "Scythe of vitur",
  "quantity": 1,
  "occurredAt": "2026-07-02T18:30:00Z",
  "dedupeKey": "manual-scythe-1"
}

### 12. Public events
GET {{baseUrl}}/api/events

### 12. Public event by slug
GET {{baseUrl}}/api/events/{{eventSlug}}

### 12. Public event board
GET {{baseUrl}}/api/events/{{eventSlug}}/board

### 12. Public event teams
GET {{baseUrl}}/api/events/{{eventSlug}}/teams

### 12. Public team board
GET {{baseUrl}}/api/events/{{eventSlug}}/teams/{{teamId}}/board

### 12. Public event contributions
GET {{baseUrl}}/api/events/{{eventSlug}}/contributions

### 12. Public read-only TempleOSRS refresh request
POST {{baseUrl}}/api/events/{{eventSlug}}/templeosrs/refresh
